# Jellyfin server URL (no trailing slash)
JELLYFIN_URL=http://localhost:8096

# Jellyfin API Key (generate in Dashboard > API Keys)
JELLYFIN_API_KEY=your_api_key_here

# Server port
PORT=3001

# Overseerr / Jellyseerr (optional - leave blank to disable)
# URL of your Overseerr/Jellyseerr instance (no trailing slash)
OVERSEERR_URL=http://localhost:5055
# API Key (generate in Overseerr Settings > General)
OVERSEERR_API_KEY=your_overseerr_api_key_here